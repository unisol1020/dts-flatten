{
  "name": "dts-resolver",
  "version": "0.1.0",
  "description": "Generate minimal .d.ts by resolving TypeScript types down to their structural primitives.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "dts-resolver": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "typescript",
    "dts",
    "d.ts",
    "types",
    "resolve",
    "flatten",
    "declaration"
  ],
  "license": "MIT",
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "devDependencies": {
    "@sinclair/typebox": "^0.34.0",
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^6.0.0",
    "vitest": "^2.0.0"
  }
}
